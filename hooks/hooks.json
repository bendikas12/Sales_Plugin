{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/load-hubspot-glossary.sh",
            "statusMessage": "Loading HubSpot glossary..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/load-guru-guidance.sh",
            "statusMessage": "Loading Guru connector guidance..."
          }
        ]
      }
    ]
  }
}
